          <parameter desc="Current limit for HVRCM, pu (negative)" name="Iolim" group="" unit="pu" min="-10" max="0" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[-1.3]]></value>
            <cond>
            </cond>
            <help>
            </help>
          </parameter>
          <parameter desc="Voltage filter time constant for LVRCM (s)" name="Tfltr_regca" group="" unit="s" min="0" max="1" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[0.02]]></value>
            <cond>
            </cond>
            <help>
            </help>
          </parameter>
          <parameter desc="Overvoltage compensation gain used in HVRCM (between 0 and 1)" name="Khv" group="" unit="" min="0" max="1" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[0.0]]></value>
            <cond>
            </cond>
            <help>
            </help>
          </parameter>
          <parameter desc="Upper limit on Rate of change for  reactive curent (pu/s)" name="Iqrmax" group="" unit="pu/s" min="0" max="1000" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[100]]></value>
            <cond>
            </cond>
            <help>
            </help>
          </parameter>
          <parameter desc="Lower limit on Rate of change for  reactive curent (pu/s)" name="Iqrmin" group="" unit="pu/s" min="-1000" max="0" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[-100.0]]></value>
            <cond>
            </cond>
            <help>
            </help>
          </parameter>
          <parameter desc="Acc. factor for smoothing out voltage &amp; angle calculations (between 0 and 1)" name="Accel" group="" unit="" min="0" max="1" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[0.7]]></value>
            <cond>
            </cond>
            <help>
            </help>
          </parameter>
          <parameter desc="LVPL switch, 0: LVPL not present, 1: LVPL present" name="Lvplsw" group="Flag" unit="" min="0" max="1" content_type="Constant" type="Integer" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[0]]></value>
            <cond>
            </cond>
            <help>
            </help>
          </parameter>
          <parameter desc="Base frequency (Hz)" name="fbase" group="Base" unit="Hz" min="40" max="70" content_type="Variable" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[60]]></value>
            <cond>
            </cond>
            <help>
            </help>
          </parameter>
          <parameter desc="Base voltage (L-L RMS)" name="vbase" group="Base" unit="kV" min="0" max="1000" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[20]]></value>
            <cond>
            </cond>
            <help>
            </help>
          </parameter>
          <parameter desc="Base MVA" name="mbase" group="Base" unit="MVA" min="0" max="10000" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[10]]></value>
            <cond>
